# =============================================================================
# CloudCost IQ - Template de Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e configure os valores para seu ambiente
#
# Formato Suportado:
#   - Linux/macOS: export VARIAVEL=valor
#   - Docker Compose: VARIAVEL=valor (sem export)
#   - Windows (CMD): set VARIAVEL=valor
#   - Windows (PowerShell): $env:VARIAVEL="valor"
# =============================================================================

# =============================================================================
# CONFIGURAÇÃO AWS
# =============================================================================
# Credenciais da AWS com permissões para Cost Explorer
# Obtidas em: IAM > Usuários > Credenciais de Acesso
#
# IMPORTANTE: Criar usuário IAM específico com permissões limitadas:
#   - ce:GetCostAndUsage
#   - ce:GetDimensionValues
#   - ce:GetTags

AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLEKEY
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1

# =============================================================================
# CONFIGURAÇÃO DO BANCO DE DADOS
# =============================================================================
# String de conexão PostgreSQL
# Formato: postgresql://[usuário]:[senha]@[host]:[porta]/[database]
#
# Desenvolvimento Local (Docker):
DATABASE_URL=postgresql://postgres:postgres@db:5432/cloudcostiq

# Produção (AWS RDS):
# DATABASE_URL=postgresql://usuario:senha@endpoint-rds.amazonaws.com:5432/cloudcostiq

# =============================================================================
# CONFIGURAÇÃO DA APLICAÇÃO
# =============================================================================
# Chave secreta para assinatura de tokens JWT
# IMPORTANTE: Gerar chave aleatória forte para produção
# Gerador: openssl rand -hex 32
SECRET_KEY=sua-chave-secreta-aqui-mude-em-producao

# Algoritmo de assinatura JWT
# Opções: HS256, HS384, HS512
ALGORITHM=HS256

# Tempo de expiração do token de acesso (em minutos)
# Recomendado: 30 minutos para produção
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# CONFIGURAÇÕES OPCIONAIS
# =============================================================================

# Ambiente de execução (development, production)
# ENVIRONMENT=development

# Debug mode (true/false) - Apenas desenvolvimento
# DEBUG=true

# Host da API (0.0.0.0 para todas as interfaces)
# API_HOST=0.0.0.0

# Porta da API
# API_PORT=8000

# =============================================================================
# CONFIGURAÇÃO DE E-MAIL (FUTURO)
# =============================================================================
# Para funcionalidades de notificação por e-mail

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu-email@gmail.com
# SMTP_PASSWORD=sua-senha-app
# SMTP_FROM=CloudCost IQ <noreply@seudominio.com>

# =============================================================================
# INTEGRAÇÕES EXTERNAS (FUTURO)
# =============================================================================

# Slack Webhook para notificações
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXX

# Datadog APM
# DATADOG_API_KEY=sua-datadog-api-key

